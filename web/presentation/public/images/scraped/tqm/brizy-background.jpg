ss-1fmkm3" data-brz-custom-id="vwcogqhzxtdsmwzpoepuzgiyvipopmcgjira"><div class="brz-icon__container" data-brz-custom-id="ttfjiothkjbjtwnvhscbboaoovjshgwnxevw"><span class="brz-icon brz-span brz-css-73bf41 brz-css-2tgfa6"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/scale-4.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-fo8k7w brz-css-v1l2uo" data-brz-custom-id="wqtrhqoxpfzougamdshrbdtzuupbwtuhfmvo"><div data-brz-translate-text="1"><h5 class="brz-fs-xs-im-20 brz-fs-sm-im-21 brz-fs-lg-22 brz-fw-xs-im-500 brz-fw-sm-im-500 brz-fw-lg-500 brz-ft-google brz-ff-ubuntu brz-ls-xs-im-0 brz-ls-sm-im-0 brz-ls-lg-0 brz-lh-xs-im-1_4 brz-lh-sm-im-1_4 brz-lh-lg-1_5 brz-mb-lg-0 brz-css-nUPB9"><span class="brz-cp-color8">Purity</span></h5><p class="brz-fw-xs-im-300 brz-fw-sm-im-300 brz-fw-lg-300 brz-ft-google brz-ff-spinnaker brz-ls-xs-im-0 brz-ls-sm-im-0 brz-ls-lg-0 brz-fs-xs-im-16 brz-fs-sm-im-16 brz-fs-lg-17 brz-lh-xs-im-1_3 brz-lh-sm-im-1_3 brz-lh-lg-1_3 brz-css-lqyt_"><strong class="brz-cp-color7">Our Copper is derived from the processing of complex ore and sold as pure copper concentrate. </strong></p></div></div></div></div></div><div id="" class="brz-css-7ylsti brz-css-15wokb0 brz-wrapper"><div class="brz-icon-text brz-css-1d4xq36 brz-css-1q8c7o2" data-brz-custom-id="aaiwhmifmrnzptwbtjoalwhpmwscpbyccpnw"><div class="brz-icon__container" data-brz-custom-id="pttwogjkcpyvroykufadtokccgnojvivlmpf"><span class="brz-icon brz-span brz-css-73bf41 brz-css-h03h8b"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/tractor.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-fo8k7w brz-css-74mpgh" data-brz-custom-id="wwykzdzvbojwvtiufmavwlmhswhlnpusnqic"><div data-brz-translate-text="1"><h5 class="brz-mb-lg-0 brz-lh-lg-1_5 brz-lh-sm-im-1_4 brz-lh-xs-im-1_4 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-ubuntu brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-fs-lg-22 brz-fs-sm-im-21 brz-fs-xs-im-20 brz-css-m4W4e"><span class="brz-cp-color8">Production Capacity</span></h5><p class="brz-lh-lg-1_3 brz-lh-sm-im-1_3 brz-lh-xs-im-1_3 brz-fs-lg-17 brz-fs-sm-im-16 brz-fs-xs-im-16 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-spinnaker brz-ft-google brz-fw-lg-300 brz-fw-sm-im-300 brz-fw-xs-im-300 brz-css-ylTc2"><strong class="brz-cp-color7">Our productional capacity is currently at 2,000 MT / Month. </strong></p></div></div></div></div></div><div id="" class="brz-css-7ylsti brz-css-1tlx908 brz-wrapper"><div class="brz-icon-text brz-css-1d4xq36 brz-css-sp8xab" data-brz-custom-id="iybphomdbmfjuecbhayvmoobmvzrsqynzdvn"><div class="brz-icon__container" data-brz-custom-id="juhbkytvhuzwzhihynorhbqndtmmzyuyrxck"><span class="brz-icon brz-span brz-css-73bf41 brz-css-nwfcnm"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/boat-front.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-fo8k7w brz-css-1w5hmum" data-brz-custom-id="zenemxdtaxblowvwxfdpysxhatlsyzfjejiq"><div data-brz-translate-text="1"><h5 class="brz-fs-xs-im-20 brz-fs-sm-im-21 brz-fs-lg-22 brz-fw-xs-im-500 brz-fw-sm-im-500 brz-fw-lg-500 brz-ft-google brz-ff-ubuntu brz-ls-xs-im-0 brz-ls-sm-im-0 brz-ls-lg-0 brz-lh-xs-im-1_4 brz-lh-sm-im-1_4 brz-lh-lg-1_5 brz-mb-lg-0 brz-css-kVaks"><span class="brz-cp-color8">Logistics</span></h5><p class="brz-ls-xs-im-m_1 brz-ls-sm-im-m_1 brz-ls-lg-m_0_5 brz-text-lg-justify brz-fs-xs-im-16 brz-fs-sm-im-16 brz-fs-lg-17 brz-lh-xs-im-1_3 brz-lh-sm-im-1_3 brz-lh-lg-1_3 brz-ff-spinnaker brz-ft-google brz-fw-lg-400 brz-fw-sm-im-400 brz-fw-xs-im-400 brz-text-sm-left brz-css-sx0Hg"><strong class="brz-cp-color7">Our iron ore is typically shipped by ocean freight out of the port of Mati on the Island of Mindanao, Philippines. Shipping options of CIF and FOB are offered.</strong></p></div></div></div></div></div></div></div><div class="brz-columns brz-css-15y0gpu brz-css-1tg7p8s" data-brz-custom-id="yddxwlkxnbtxsvkefmlfzklnkrskfmbpyhgf"><div class="brz-bg"><div class="brz-bg-image"></div></div><div class="brz-column__items brz-css-9rk3v1 brz-css-tqwz8h"><div id="" class="brz-css-7ylsti brz-css-79nlr7 brz-css-odgh8s brz-wrapper"><div class="brz-spacer brz-css-fqd3pu brz-css-562ind"></div></div></div></div></div></div></div></div></section><section id="manganese" data-brz-id="noanqvqiqyscaczinwyidpuoewxircwmmhgv_noanqvqiqyscaczinwyidpuoewxircwmmhgv" class="brz-section brz-css-yuipv2 brz-css-o9rcr8"><div class="brz-section__content brz-section--boxed brz-css-12iu3ip brz-css-1hnyuex" data-brz-custom-id="nfmtehsmbbhvjoqbszjgskgrssrcdnnnzzhq"><div class="brz-bg"><div class="brz-bg-color"></div></div><div class="brz-container brz-css-1e5nk42 brz-css-v5f8h5"><div class="brz-row__container brz-css-14z9hnh brz-css-1pwkra6" data-brz-custom-id="dmxzgkzgpkutbkbycrhxlleonirzphneunzk"><div class="brz-row brz-css-dgef8v brz-css-1nlvjcw brz-css-1f3g2kg"><div class="brz-columns brz-css-10os54r brz-css-d2j8ah" data-brz-custom-id="mqdhcfuxtriyvjsqhlsolgbnfkodwtrrutsa"><div class="brz-column__items brz-css-tqkjtc brz-css-1odvlvq"><div id="" class="brz-css-1b3qwdx brz-css-1ew54xn brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-1t3let1 brz-css-5fc35b" data-brz-custom-id="rmttvsjhpltxqsotqqyrmpaxohmsoqjsagqg"><div data-brz-translate-text="1"><h2 class="brz-fw-xs-im-700 brz-fw-sm-im-700 brz-fw-lg-700 brz-ft-google brz-ff-montserrat brz-ls-xs-im-m_0_5 brz-ls-sm-im-m_0_5 brz-ls-lg-m_1_5 brz-fs-xs-im-30 brz-fs-sm-im-35 brz-fs-lg-42 brz-lh-xs-im-1_2 brz-lh-sm-im-1_2 brz-lh-lg-1_2 brz-text-xs-center brz-css-f5PD_"><span class="brz-cp-color1">Manganese (Mg)</span></h2></div></div></div><div id="" class="brz-css-1b3qwdx brz-css-6b78yg brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-1t3let1 brz-css-rxelg" data-brz-custom-id="xpweqwsdwyzbptfcwonwlgnxzdldqjjeejql"><div data-brz-translate-text="1"><p class="brz-ls-xs-0 brz-fw-xs-400 brz-lh-xs-1_2 brz-fs-xs-16 brz-ls-lg-m_1 brz-text-xs-center brz-ff-ubuntu brz-ft-google brz-fw-lg-300 brz-text-lg-justify brz-fs-sm-16 brz-lh-sm-1_2 brz-fw-sm-400 brz-ls-sm-0 brz-text-sm-left brz-fs-lg-22 brz-lh-lg-1_2 brz-css-pfz6T"><span class="brz-cp-color1">Manganese is mainly&nbsp;used&nbsp;in alloys, such as steel. Manganese is&nbsp;used&nbsp;as a catalyst, a rubber additive and to decolorize glass that is colored green by iron impurities.&nbsp;Manganese&nbsp;sulfate is&nbsp;used&nbsp;to make a fungicide.</span></p></div></div></div><div id="" class="brz-css-1b3qwdx brz-css-1dvd5sh brz-css-1f8becu brz-wrapper"><div class="brz-spacer brz-css-q67v4a brz-css-1iy1o5n"></div></div><div id="" class="brz-css-1b3qwdx brz-css-ivfyz1 brz-wrapper"><div class="brz-icon-text brz-css-1vud5o2 brz-css-139oqdg" data-brz-custom-id="iwzunjovkeouwjavhzvrjnabdagpwsxpdigx"><div class="brz-icon__container" data-brz-custom-id="rrcbumsiqfkbqalbkdjtxfmzbtlndbzuzyzs"><span class="brz-icon brz-span brz-css-1qrt832 brz-css-1l6xqdw"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/scale-4.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-1t3let1 brz-css-cp1jf" data-brz-custom-id="zstccpjzmehdwjxcnfsqvbceczfsbwfmcpaz"><div data-brz-translate-text="1"><h5 class="brz-mb-lg-0 brz-lh-lg-1_5 brz-lh-sm-im-1_4 brz-lh-xs-im-1_4 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-ubuntu brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-fs-lg-22 brz-fs-sm-im-21 brz-fs-xs-im-20 brz-css-eFrXx"><span class="brz-cp-color1">Purity</span></h5><p class="brz-lh-lg-1_3 brz-lh-sm-im-1_3 brz-lh-xs-im-1_3 brz-fs-lg-17 brz-fs-sm-im-16 brz-fs-xs-im-16 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-montserrat brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-css-oDQqk"><span class="brz-cp-color7">Our high grade iron ore is assayed at 67% iron content. It is sold at a guaranteed 64% purity.</span></p></div></div></div></div></div><div id="" class="brz-css-1b3qwdx brz-css-yc9ugi brz-wrapper"><div class="brz-icon-text brz-css-1vud5o2 brz-css-169yssy" data-brz-custom-id="ezyexalymvpoitdtpteadmwygcbhofgtzetz"><div class="brz-icon__container" data-brz-custom-id="fccwnhzdrdokqpguiozgntayjpgqltkutslo"><span class="brz-icon brz-span brz-css-1qrt832 brz-css-14e3h3t"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/tractor.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-1t3let1 brz-css-m2wyuj" data-brz-custom-id="eladyrhzfxxdelpprksshxfeqralnuzwjzrx"><div data-brz-translate-text="1"><h5 class="brz-mb-lg-0 brz-lh-lg-1_5 brz-lh-sm-im-1_4 brz-lh-xs-im-1_4 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-ubuntu brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-fs-lg-22 brz-fs-sm-im-21 brz-fs-xs-im-20 brz-css-fnseT"><span class="brz-cp-color1">Production Capacity</span></h5><p class="brz-lh-lg-1_3 brz-lh-sm-im-1_3 brz-lh-xs-im-1_3 brz-fs-lg-17 brz-fs-sm-im-16 brz-fs-xs-im-16 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-montserrat brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-css-lUS8i"><span class="brz-cp-color7">Our productional capacity is currently at 500,000 MT / Month. This can be scaled for the right buyer. </span></p></div></div></div></div></div><div id="" class="brz-css-1b3qwdx brz-css-sd5jot brz-wrapper"><div class="brz-icon-text brz-css-1vud5o2 brz-css-158nuy1" data-brz-custom-id="ymgdivmyaqvviyhfsxgupllfvozaovallbmf"><div class="brz-icon__container" data-brz-custom-id="aateaechwspudvdyerkhvpqpluojpdflfggp"><span class="brz-icon brz-span brz-css-1qrt832 brz-css-jdyuuh"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/boat-front.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-1t3let1 brz-css-18ldtrb" data-brz-custom-id="pwqcnkivjvbbceirdzhchwunrugqsaztnval"><div data-brz-translate-text="1"><h5 class="brz-mb-lg-0 brz-lh-lg-1_5 brz-lh-sm-im-1_4 brz-lh-xs-im-1_4 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-ubuntu brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-fs-lg-22 brz-fs-sm-im-21 brz-fs-xs-im-20 brz-css-faOf_"><span class="brz-cp-color1">Logistics</span></h5><p class="brz-fw-xs-im-500 brz-fw-sm-im-500 brz-fw-lg-500 brz-ft-google brz-ff-montserrat brz-text-lg-justify brz-lh-lg-1_3 brz-lh-sm-im-1_3 brz-lh-xs-im-1_3 brz-fs-lg-17 brz-fs-sm-im-16 brz-fs-xs-im-16 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-text-sm-left brz-css-yFkw0"><span class="brz-cp-color7">Our iron ore is typically shipped by ocean freight out of the port of Mati on the Island of Mindanao, Philippines. Shipping options of CIF and FOB are offered.</span></p></div></div></div></div></div></div></div><div class="brz-columns brz-css-10os54r brz-css-m654s6" data-brz-custom-id="xkbvulcirpgbddgifsthpxuzmcwavabavpdi"><div class="brz-bg"><div class="brz-bg-image"></div></div><div class="brz-column__items brz-css-tqkjtc brz-css-12yum9o"><div id="" class="brz-css-1b3qwdx brz-css-1dvd5sh brz-css-1ji9zgo brz-wrapper"><div class="brz-spacer brz-css-q67v4a brz-css-1arxpqu"></div></div></div></div></div></div></div></div></section><section id="nickel" data-brz-id="mzsznlxoduierayrrlmrrjpjgwxxjibxmfdo_mzsznlxoduierayrrlmrrjpjgwxxjibxmfdo" class="brz-section brz-css-1cbv2mc brz-css-w15xwl"><div class="brz-section__content brz-section--boxed brz-css-1p6n9mn brz-css-sxx4qn" data-brz-custom-id="lhrfosohlvfxozptrrwvynctggolcueknjbo"><div class="brz-bg"><div class="brz-bg-color"></div><div class="brz-bg-shape brz-bg-shape__top"></div></div><div class="brz-container brz-css-1kq0cao brz-css-1eveqfk"><div class="brz-row__container brz-css-4g2jig brz-css-14v0gvl" data-brz-custom-id="uqwpjmiwcycjcurnakaailqdezcxcvblgswg"><div class="brz-row brz-css-1tmgakk brz-css-e59kec brz-css-x5a6nx"><div class="brz-columns brz-css-1ri0w15 brz-css-yu9eef" data-brz-custom-id="aglhfvokqhdwatquwneeqierknxjhipfwwgw"><div class="brz-column__items brz-css-d8khzw brz-css-16ahpwm"><div id="" class="brz-css-9cjib9 brz-css-17bb3kz brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-1jx7m9l brz-css-18zjvzw" data-brz-custom-id="qpqsmzjbhiphfsiyamrotodxmtpdgddgixzv"><div data-brz-translate-text="1"><h2 class="brz-fw-xs-im-700 brz-fw-sm-im-700 brz-fw-lg-700 brz-ft-google brz-ff-montserrat brz-ls-xs-im-m_0_5 brz-ls-sm-im-m_0_5 brz-ls-lg-m_1_5 brz-fs-xs-im-30 brz-fs-sm-im-35 brz-fs-lg-42 brz-lh-xs-im-1_2 brz-lh-sm-im-1_2 brz-lh-lg-1_2 brz-text-xs-center brz-css-fIgEs"><span class="brz-cp-color8">Nickel (Ni)</span></h2></div></div></div><div id="" class="brz-css-9cjib9 brz-css-3fyxmi brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-1jx7m9l brz-css-elhsbn" data-brz-custom-id="wvlcpzsiuffqmnoqobpawlhtzrfwnbiheaaz"><div data-brz-translate-text="1"><p class="brz-fw-xs-400 brz-ls-xs-0 brz-lh-xs-1_2 brz-fs-xs-16 brz-fw-lg-500 brz-text-xs-center brz-ff-ubuntu brz-ft-google brz-text-lg-justify brz-fs-sm-16 brz-lh-sm-1_2 brz-fw-sm-400 brz-ls-sm-0 brz-text-sm-left brz-fs-lg-22 brz-lh-lg-1_2 brz-ls-lg-m_1 brz-ls-sm-im-m_1 brz-ls-xs-im-m_1 brz-css-vss9E"><span class="brz-cp-color8">Some nickel&nbsp;production&nbsp;is used for alloying elements, coatings, batteries, and some other uses, such as kitchen wares, mobile phones, medical equipment, transport, buildings, power generation and jewelry. Most nickel is used the&nbsp;production&nbsp;of ferronickel for stainless&nbsp;steel.</span></p></div></div></div><div id="" class="brz-css-9cjib9 brz-css-181fl84 brz-css-u5mrz6 brz-wrapper"><div class="brz-spacer brz-css-8dptjv brz-css-1wej6jq"></div></div><div id="" class="brz-css-9cjib9 brz-css-fnys2e brz-wrapper"><div class="brz-icon-text brz-css-lfh3n6 brz-css-zduk2l" data-brz-custom-id="bbithdbqmepxyfsccyeldkxpuesleecxkmbw"><div class="brz-icon__container" data-brz-custom-id="tfvvlchcpwzkaqlsbsqhhunqfunpzpzjmnpf"><span class="brz-icon brz-span brz-css-v9oeey brz-css-q4knaz"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/scale-4.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-1jx7m9l brz-css-c1bfdk" data-brz-custom-id="gbeitshcuwoarpawvecrqabnsyvhzjoxtiez"><div data-brz-translate-text="1"><h5 class="brz-fs-xs-im-20 brz-fs-sm-im-21 brz-fs-lg-22 brz-fw-xs-im-500 brz-fw-sm-im-500 brz-fw-lg-500 brz-ft-google brz-ff-ubuntu brz-ls-xs-im-0 brz-ls-sm-im-0 brz-ls-lg-0 brz-lh-xs-im-1_4 brz-lh-sm-im-1_4 brz-lh-lg-1_5 brz-mb-lg-0 brz-css-xtg_M"><span class="brz-cp-color8">Purity</span></h5><p class="brz-fw-xs-im-300 brz-fw-sm-im-300 brz-fw-lg-300 brz-ft-google brz-ff-spinnaker brz-ls-xs-im-0 brz-ls-sm-im-0 brz-ls-lg-0 brz-fs-xs-im-16 brz-fs-sm-im-16 brz-fs-lg-17 brz-lh-xs-im-1_3 brz-lh-sm-im-1_3 brz-lh-lg-1_3 brz-css-suap5"><strong class="brz-cp-color7">Our Copper is derived from the processing of complex ore and sold as pure copper concentrate. </strong></p></div></div></div></div></div><div id="" class="brz-css-9cjib9 brz-css-hbtifu brz-wrapper"><div class="brz-icon-text brz-css-lfh3n6 brz-css-kq2nnl" data-brz-custom-id="hnrdepzwupxdwypkjsbunyvrajqmwvpdbpkg"><div class="brz-icon__container" data-brz-custom-id="dkedhwchrvdkwurabwiygbnozlbjjypmsiuj"><span class="brz-icon brz-span brz-css-v9oeey brz-css-1xg9m9f"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/tractor.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-1jx7m9l brz-css-etnfrr" data-brz-custom-id="crfxbcqqtfzzodfjgrnmlsrujlpmlfczivhn"><div data-brz-translate-text="1"><h5 class="brz-mb-lg-0 brz-lh-lg-1_5 brz-lh-sm-im-1_4 brz-lh-xs-im-1_4 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-ubuntu brz-ft-google brz-fw-lg-500 brz-fw-sm-im-500 brz-fw-xs-im-500 brz-fs-lg-22 brz-fs-sm-im-21 brz-fs-xs-im-20 brz-css-giUaz"><span class="brz-cp-color8">Production Capacity</span></h5><p class="brz-lh-lg-1_3 brz-lh-sm-im-1_3 brz-lh-xs-im-1_3 brz-fs-lg-17 brz-fs-sm-im-16 brz-fs-xs-im-16 brz-ls-lg-0 brz-ls-sm-im-0 brz-ls-xs-im-0 brz-ff-spinnaker brz-ft-google brz-fw-lg-300 brz-fw-sm-im-300 brz-fw-xs-im-300 brz-css-ax3Hn"><strong class="brz-cp-color7">Our productional capacity is currently at 2,000 MT / Month. </strong></p></div></div></div></div></div><div id="" class="brz-css-9cjib9 brz-css-1n4euy3 brz-wrapper"><div class="brz-icon-text brz-css-lfh3n6 brz-css-12q2806" data-brz-custom-id="qfqotdybbgzsflacizvjvwsfmrrhwoxbmheb"><div class="brz-icon__container" data-brz-custom-id="icjaylykhpjlxpwjvrzrrrzpqywynadnfdnv"><span class="brz-icon brz-span brz-css-v9oeey brz-css-qf1o9c"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/boat-front.svg#nc_icon"></use></svg></span></div><div class="brz-text-btn"><div class="brz-rich-text brz-rich-text__custom brz-css-1jx7m9l brz-css-qw6lhc" data-brz-custom-id="uxnpzdvidtyanywhuppuavonguhrjrumqize"><div data-brz-translate-text="1"><h5 class="brz-fs-xs-im-20 brz-fs-sm-im-21 brz-fs-lg-22 brz-fw-xs-im-500 brz-fw-sm-im-500 brz-fw-lg-500 brz-ft-google brz-ff-ubuntu brz-ls-xs-im-0 brz-ls-sm-im-0 brz-ls-lg-0 brz-lh-xs-im-1_4 brz-lh-sm-im-1_4 brz-lh-lg-1_5 brz-mb-lg-0 brz-css-nR7F1"><span class="brz-cp-color8">Logistics</span></h5><p class="brz-ls-xs-im-m_1 brz-ls-sm-im-m_1 brz-ls-lg-m_0_5 brz-text-lg-justify brz-fs-xs-im-16 brz-fs-sm-im-16 brz-fs-lg-17 brz-lh-xs-im-1_3 brz-lh-sm-im-1_3 brz-lh-lg-1_3 brz-ff-spinnaker brz-ft-google brz-fw-lg-400 brz-fw-sm-im-400 brz-fw-xs-im-400 brz-text-sm-left brz-css-iQx5v"><strong class="brz-cp-color7">Our iron ore is typically shipped by ocean freight out of the port of Mati on the Island of Mindanao, Philippines. Shipping options of CIF and FOB are offered.</strong></p></div></div></div></div></div></div></div><div class="brz-columns brz-css-1ri0w15 brz-css-3vtmb6" data-brz-custom-id="bwnlblxrxvcfarudqkjuhbvccexurbyatsre"><div class="brz-bg"><div class="brz-bg-image"></div></div><div class="brz-column__items brz-css-d8khzw brz-css-4genkq"><div id="" class="brz-css-9cjib9 brz-css-181fl84 brz-css-1hjolea brz-wrapper"><div class="brz-spacer brz-css-8dptjv brz-css-886q90"></div></div></div></div></div></div></div></div></section><section id="ywmjrldpdbecvgzlgnptcgcmclianljtyudw_ywmjrldpdbecvgzlgnptcgcmclianljtyudw" class="brz-section brz-css-17frypr brz-css-3bf5bj"><div class="brz-section__content brz-section--boxed brz-css-w4cm9h brz-css-kxhiql" data-brz-custom-id="ikjjbzcqnlvtcvodkvttpmxhqekntwtmoioq"><div class="brz-bg"><div class="brz-bg-color"></div></div><div class="brz-container brz-css-2uol3c brz-css-1bqzlsg"><div class="brz-row__container brz-css-1iox0vi brz-css-ojytzr" data-brz-custom-id="zgdtttkizsgbxrdnfxomqofwifaenjnkdlcm"><div class="brz-row brz-css-1cpszau brz-css-1afcmtw brz-css-lueiwc"><div class="brz-columns brz-css-6esh13 brz-css-1l8lz7o" data-brz-custom-id="vwcxdgpdsprjxzohadhmvqpykcyskietufzy"><div class="brz-bg"><div class="brz-bg-color"></div></div><div class="brz-column__items brz-css-1v2z0l3 brz-css-152n2ws"><div class="brz-wrapper-clone brz-flex-xs-wrap brz-css-uo2td5 brz-css-oceqh3" data-brz-custom-id="ltpyxqwkmhmenfgxpzjvbzrfuscvmkvmxyna"><div class="brz-icon__container" data-brz-custom-id="risrbzlfoncqfbmevplkyrtgskfvtrcubpis"><span class="brz-icon brz-span brz-css-1vkma8z brz-css-1o7v1zb"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/world.svg#nc_icon"></use></svg></span></div></div><div id="" class="brz-css-htac6q brz-css-am7ie0 brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-12q8kru" data-brz-custom-id="lienkgamzqymbkmmoeivstdwnlxvioccpgld"><div data-brz-translate-text="1"><h5 class="brz-text-lg-center brz-tp-heading5 brz-css-illBk"><span class="brz-cp-color1">Ethically Sourced</span></h5></div></div></div><div id="" class="brz-css-htac6q brz-css-1891mjo brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-1sli189" data-brz-custom-id="jsqtdtcqfjdntxadpfrmpmekuxumlkbhqqwf"><div data-brz-translate-text="1"><p class="brz-mb-xs-10 brz-text-lg-center brz-tp-paragraph brz-mb-lg-0 brz-css-aO1c9"><span class="brz-cp-color7">We value our workforce, our community, and our environment. All of our minerals are mined with the highest standards.</span></p></div></div></div></div></div><div class="brz-columns brz-css-6esh13 brz-css-186qra8" data-brz-custom-id="hensamkiwvdpadvdeidxwbzbjsgrfbajybbo"><div class="brz-bg"><div class="brz-bg-color"></div></div><div class="brz-column__items brz-css-1v2z0l3 brz-css-1a2hvq0"><div class="brz-wrapper-clone brz-flex-xs-wrap brz-css-uo2td5 brz-css-15dncqk" data-brz-custom-id="sggczrabqwxvwyhpzgtgjzrirsyertvpwhdu"><div class="brz-icon__container" data-brz-custom-id="xiumryldtkfffxsxydeposhzvhryscadqvav"><span class="brz-icon brz-span brz-css-1vkma8z brz-css-1pbdd11"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/tractor.svg#nc_icon"></use></svg></span></div></div><div id="" class="brz-css-htac6q brz-css-190oq3e brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-11mq348" data-brz-custom-id="durosxvvmmzneozbejujpzkdzbwjejgndmap"><div data-brz-translate-text="1"><h5 class="brz-text-lg-center brz-tp-heading5 brz-css-q5yMA"><span class="brz-cp-color1">Massive Deposits</span></h5></div></div></div><div id="" class="brz-css-htac6q brz-css-72yt4p brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-w5am5l" data-brz-custom-id="vobvwtsocddoqgqdgcmlkqrktyhdlzzadbyl"><div data-brz-translate-text="1"><p class="brz-text-lg-center brz-tp-paragraph brz-css-kdFeu"><span class="brz-cp-color7">Featuring hundreds of millions of metric tons of minerals, our mining sites are able to produce consistent quantities of top grade ore. </span></p></div></div></div></div></div><div class="brz-columns brz-css-6esh13 brz-css-zee97u" data-brz-custom-id="qvaqjsclklauwwsisnxucwmlvpmibxnfpczi"><div class="brz-bg"><div class="brz-bg-color"></div></div><div class="brz-column__items brz-css-1v2z0l3 brz-css-4sbizy"><div class="brz-wrapper-clone brz-flex-xs-wrap brz-css-uo2td5 brz-css-1qopvfo" data-brz-custom-id="gbyjoxxupzxzfpwefnguflapmwzyyxzhezcp"><div class="brz-icon__container" data-brz-custom-id="xmgmuivxlcfsiqdymrmxugnxiixofqvxqmhs"><span class="brz-icon brz-span brz-css-1vkma8z brz-css-11uzpb1"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/coins.svg#nc_icon"></use></svg></span></div></div><div id="" class="brz-css-htac6q brz-css-ymxhc3 brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-wjljds" data-brz-custom-id="skezvyescggxuhdflmiruyehdvjyhqtjkflo"><div data-brz-translate-text="1"><h5 class="brz-text-lg-center brz-tp-heading5 brz-css-jsprN"><span class="brz-cp-color1">Competitive Rates </span></h5></div></div></div><div id="" class="brz-css-htac6q brz-css-799o3o brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-jpjnlq" data-brz-custom-id="wslnwqdiexomgghpautcjofjhedilxzzsddc"><div data-brz-translate-text="1"><p class="brz-text-lg-center brz-tp-paragraph brz-css-v9PXQ"><span class="brz-cp-color7">Get high grade ore and very good pricing. We are able to compete with suppliers around the world because of high quality and good value.</span></p></div></div></div></div></div><div class="brz-columns brz-css-6esh13 brz-css-1730wwi" data-brz-custom-id="xeuruatbdrhmlcdzheyttgtfvfiewbqykiyc"><div class="brz-bg"><div class="brz-bg-color"></div></div><div class="brz-column__items brz-css-1v2z0l3 brz-css-iw7cff"><div class="brz-wrapper-clone brz-flex-xs-wrap brz-css-uo2td5 brz-css-177q1am" data-brz-custom-id="aofspatoamfapibgxjesuofvrirdndqwzomn"><div class="brz-icon__container" data-brz-custom-id="tjdzukswdoitccbyxoetgzwkwfzmqfjowomn"><span class="brz-icon brz-span brz-css-1vkma8z brz-css-uoafzw"><svg class="brz-icon-svg align-[initial]"><use href="/wp-content/plugins/brizy/public/editor-build/prod/editor/icons/outline/anchor.svg#nc_icon"></use></svg></span></div></div><div id="" class="brz-css-htac6q brz-css-hdckt1 brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-5vpupu" data-brz-custom-id="lmhpmfyrgmkixdynlwpcdlmidpjhezmkhdtt"><div data-brz-translate-text="1"><h5 class="brz-tp-heading5 brz-text-lg-center brz-css-mJ1WW"><span class="brz-cp-color1">Worldwide Shipping</span></h5></div></div></div><div id="" class="brz-css-htac6q brz-css-1br3rbc brz-wrapper"><div class="brz-rich-text brz-rich-text__custom brz-css-ijhrmk brz-css-1bdakfg" data-brz-custom-id="wvchrdmldvlbiblkrodllliryagipddkhjpc"><div data-brz-translate-text="1"><p class="brz-text-lg-center brz-tp-paragraph brz-css-kTmIR"><span class="brz-cp-color7">We offer CIF and FOB shipping arrangements. We are able to ship worldwide with relatively low cost to China, Japan, Korea, &amp; Malaysia.</span></p></div></div></div></div></div></div></div></div></div></section> <!-- GLOBAL BLOCK [26038]--><section id="sgsvoxkhazdrifuudugbcvicsjtypirfcini_sgsvoxkhazdrifuudugbcvicsjtypirfcini" class="brz-section brz-css-1e0xxtv brz-css-7u3syy"><div class="brz-slick-slider brz-slick-slider__section